{
  "manifest_version": 3,
  "name": "turnstilePatch",
  "version": "1.0.0",
  "description": "Assist Cloudflare Turnstile automation",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": []
}
